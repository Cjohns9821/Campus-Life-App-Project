/* ------------------------------------------------------------
   EVENTS PAGE: Load Events (LIVE API)
------------------------------------------------------------ */

const eventsBtn = document.getElementById("loadEventsBtn");

if (eventsBtn) {
    eventsBtn.addEventListener("click", () => {
        console.log("Events button clicked");
        loadEvents();
    });
}

function loadEvents() {
    // REAL, FREE, NO‑KEY API that returns news‑style items
    const apiURL = "https://api.sampleapis.com/news/latest";

    console.log("Fetching campus news from:", apiURL);

    const eventsSection = document.getElementById("eventsSection");
    eventsSection.innerHTML = `
        <div class="alert alert-info" role="status">
            Loading campus news...
        </div>
    `;

    fetch(apiURL)
        .then(response => response.json())
        .then(data => {
            console.log("API Response:", data);

            // Use the first 3 items as “campus news”
            const items = data.slice(0, 3);

            eventsSection.innerHTML = items
                .map(item => `
                    <div class="event-card p-3 my-3 border rounded">
                        <h5>${item.title}</h5>
                        <p>${item.description}</p>
                    </div>
                `)
                .join("");
        })
        .catch(error => {
            console.warn("API error. Showing placeholder.", error);

            eventsSection.innerHTML = `
                <div class="alert alert-success">
                    <strong>Events Placeholder:</strong> Live campus news could not be loaded.
                </div>
            `;
        });
}


/* ------------------------------------------------------------
   CONTACT PAGE: Handle Contact Form Submission
   ------------------------------------------------------------ */

const contactForm = document.getElementById("contactForm");

if (contactForm) {
    contactForm.addEventListener("submit", (event) => {
        event.preventDefault(); // Prevent page reload
        console.log("Contact form submitted");

        const name = document.getElementById("nameInput").value;
        const email = document.getElementById("emailInput").value;
        const message = document.getElementById("messageInput").value;

        const responseBox = document.getElementById("contactResponse");

        responseBox.innerHTML = `
            <div class="alert alert-success mt-3">
                Thank you, <strong>${name}</strong>! Your message has been received.
                <br><small>(Email: ${email})</small>
            </div>
        `;

        contactForm.reset();
    });
}


