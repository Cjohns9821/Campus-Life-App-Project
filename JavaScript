/* ------------------------------------------------------------
   HOME PAGE: Load Campus News (LIVE API)
   ------------------------------------------------------------ */

const newsBtn = document.getElementById("loadCampusNewsBtn");

if (newsBtn) {
    newsBtn.addEventListener("click", () => {
        console.log("Campus News button clicked");
        loadCampusNews();
    });
}

function loadCampusNews() {
    const apiURL = "https://api.sampleapis.com/futurama/episodes";

    console.log("Fetching campus news from:", apiURL);

    const newsSection = document.getElementById("campusNewsSection");
    newsSection.innerHTML = `
        <div class="alert alert-info" role="status">
            Loading campus news...
        </div>
    `;

    fetch(apiURL)
        .then(response => response.json())
        .then(data => {
            const items = data.slice(0, 3); // first 3 items

            newsSection.innerHTML = items
                .map(item => `
                    <div class="announcement-card p-3 my-3 border rounded">
                        <h5>${item.title}</h5>
                        <p>${item.desc}</p>
                    </div>
                `)
                .join("");
        })
        .catch(error => {
            console.warn("Error loading campus news:", error);

            newsSection.innerHTML = `
                <div class="alert alert-danger">
                    Could not load campus news. Please try again later.
                </div>
            `;
        });
}



